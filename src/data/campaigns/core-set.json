      "name": "La Reunión",
      "texts": {
        "agenda": {
          "phases": [
            {
              "text": "La reunión empieza en silencio. Revisad vuestras manos iniciales y preparaos para investigar."
            },
            {
              "text": "Una presencia oscura recorre la casa. Colocad una ficha de perdición en el plan actual."
            }
          ]
        },
        "act": {
          "phases": [
            {
              "text": "Investigáis la casa y encontráis una pista que os lleva a la biblioteca."
            },
            {
              "text": "Investigáis la biblioteca y encontráis una pista que os lleva a la sala de estudios."
            }
          ]
        }
      }
    },
    {
      "id": "extracurricular",
      "name": "Actividad extracurricular",
      "texts": {
        "agenda": {
          "phases": [
            {
              "text": "El campus parece tranquilo, pero algo no encaja. Empezad en la biblioteca y buscad pistas."
            },
            {
              "text": "Investigáis la biblioteca y encontráis una pista que os lleva a la sala de estudios."
            }
          ]
        },
        "act": {
          "phases": [
            {
              "text": "La biblioteca está cerrada. Buscáis una manera de entrar y encontráis una pista que os lleva a la sala de estudios."
